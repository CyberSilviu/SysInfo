<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- Status Card -->
        <LinearLayout
            style="@style/InfoCard"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tvStressStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stress_status_idle"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.1" />

            <TextView
                android:id="@+id/tvElapsedTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00:00"
                android:textColor="@color/accent_cyan"
                android:textSize="42sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:layout_marginVertical="12dp" />

            <!-- Live Stats Row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_card_elevated"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CPU LOAD"
                        android:textColor="@color/text_tertiary"
                        android:textSize="10sp"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/tvCpuLoad"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textColor="@color/accent_green"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace" />
                </LinearLayout>

                <View android:layout_width="8dp" android:layout_height="match_parent" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_card_elevated"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TEMPERATURĂ"
                        android:textColor="@color/text_tertiary"
                        android:textSize="10sp"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/tvTemperature"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--°C"
                        android:textColor="@color/accent_orange"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace" />
                </LinearLayout>

                <View android:layout_width="8dp" android:layout_height="match_parent" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_card_elevated"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="THREAD-URI"
                        android:textColor="@color/text_tertiary"
                        android:textSize="10sp"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/tvActiveThreads"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/accent_purple"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace" />
                </LinearLayout>
            </LinearLayout>

            <!-- Live Stats Row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_card_elevated"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ITER/SEC"
                        android:textColor="@color/text_tertiary"
                        android:textSize="10sp"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/tvIterPerSec"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/accent_cyan"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace" />
                </LinearLayout>

                <View android:layout_width="8dp" android:layout_height="match_parent" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_card_elevated"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RAM ALOCAT"
                        android:textColor="@color/text_tertiary"
                        android:textSize="10sp"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/tvRamAllocated"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 MB"
                        android:textColor="@color/accent_yellow"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace" />
                </LinearLayout>

                <View android:layout_width="8dp" android:layout_height="match_parent" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_card_elevated"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TOTAL ITER"
                        android:textColor="@color/text_tertiary"
                        android:textSize="10sp"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/tvTotalIter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/accent_green"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- GPU OpenGL Surface — GONE until GPU stress starts, then VISIBLE -->
        <android.opengl.GLSurfaceView
            android:id="@+id/gpuSurface"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="8dp"
            android:visibility="gone" />

        <!-- Test Type Selection -->
        <LinearLayout
            style="@style/InfoCard"
            android:orientation="vertical">

            <TextView
                style="@style/SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TIP TEST"
                android:textColor="@color/accent_cyan" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="10dp"
                android:background="@color/divider" />

            <RadioGroup
                android:id="@+id/rgStressType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/rbCpuStress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="CPU Stress — încărcare maximă toate nucleele"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:buttonTint="@color/accent_cyan"
                    android:checked="true"
                    android:paddingVertical="6dp" />

                <RadioButton
                    android:id="@+id/rbMemoryStress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Memory Stress — alocare/dealocare intensivă RAM"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:buttonTint="@color/accent_cyan"
                    android:paddingVertical="6dp" />

                <RadioButton
                    android:id="@+id/rbMixedStress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Mixed Stress — CPU + Memorie combinat"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:buttonTint="@color/accent_cyan"
                    android:paddingVertical="6dp" />

                <RadioButton
                    android:id="@+id/rbGpuStress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="GPU Stress — rendering 2D intensiv 1080p"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:buttonTint="@color/accent_red"
                    android:paddingVertical="6dp" />

                <RadioButton
                    android:id="@+id/rbMixedAllStress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Mixed All — CPU + Memorie + GPU"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:buttonTint="@color/accent_orange"
                    android:paddingVertical="6dp" />
            </RadioGroup>
        </LinearLayout>

        <!-- Duration Selection -->
        <LinearLayout
            style="@style/InfoCard"
            android:orientation="vertical">

            <TextView
                style="@style/SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DURATĂ"
                android:textColor="@color/accent_cyan" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="10dp"
                android:background="@color/divider" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip1min"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1 min"
                    android:textColor="@color/text_primary"
                    android:checkable="true"
                    android:checked="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip5min"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5 min"
                    android:textColor="@color/text_primary"
                    android:checkable="true"
                    android:layout_marginStart="8dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip15min"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="15 min"
                    android:textColor="@color/text_primary"
                    android:checkable="true"
                    android:layout_marginStart="8dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipInfinite"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="∞"
                    android:textColor="@color/text_primary"
                    android:checkable="true"
                    android:layout_marginStart="8dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Thread Count -->
        <LinearLayout
            style="@style/InfoCard"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    style="@style/SectionTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="THREAD-URI"
                    android:textColor="@color/accent_cyan" />

                <TextView
                    android:id="@+id/tvThreadCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4"
                    android:textColor="@color/accent_cyan"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/seekThreads"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:min="1"
                android:max="16"
                android:progress="4"
                android:progressTint="@color/accent_cyan"
                android:thumbTint="@color/accent_cyan" />
        </LinearLayout>

        <!-- Start/Stop Button -->
        <LinearLayout
            style="@style/InfoCard"
            android:orientation="vertical"
            android:gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStartStress"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/btn_start_stress"
                android:textColor="@color/bg_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="@color/accent_green"
                android:fontFamily="monospace"
                android:letterSpacing="0.05" />
        </LinearLayout>

        <!-- Results Log -->
        <LinearLayout
            style="@style/InfoCard"
            android:orientation="vertical">

            <TextView
                style="@style/SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LOG"
                android:textColor="@color/accent_cyan" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="10dp"
                android:background="@color/divider" />

            <TextView
                android:id="@+id/tvStressLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Selectează tipul de test și apasă START.\n"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:lineSpacingExtra="4dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
