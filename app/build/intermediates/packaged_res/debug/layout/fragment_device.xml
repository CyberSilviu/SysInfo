<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- System Overview Card -->
        <LinearLayout
            style="@style/InfoCard"
            android:layout_marginTop="16dp"
            android:orientation="vertical">

            <TextView
                style="@style/SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/section_system"
                android:drawableStart="@android:drawable/ic_menu_info_details"
                android:drawablePadding="8dp"
                android:drawableTint="@color/accent_cyan" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="10dp"
                android:background="@color/divider" />

            <LinearLayout
                android:id="@+id/systemInfoContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>

        <!-- CPU Card -->
        <LinearLayout
            style="@style/InfoCard"
            android:orientation="vertical">

            <TextView
                style="@style/SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/section_cpu"
                android:drawableStart="@android:drawable/ic_menu_manage"
                android:drawablePadding="8dp"
                android:drawableTint="@color/accent_green" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="10dp"
                android:background="@color/divider" />

            <LinearLayout
                android:id="@+id/cpuInfoContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- CPU Frequency bars -->
            <LinearLayout
                android:id="@+id/cpuFreqContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical" />
        </LinearLayout>

        <!-- Memory Card -->
        <LinearLayout
            style="@style/InfoCard"
            android:orientation="vertical">

            <TextView
                style="@style/SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/section_memory"
                android:drawablePadding="8dp"
                android:drawableTint="@color/accent_orange" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="10dp"
                android:background="@color/divider" />

            <LinearLayout
                android:id="@+id/memInfoContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <ProgressBar
                android:id="@+id/memProgressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="12dp"
                android:layout_marginTop="12dp"
                android:max="100"
                android:progressDrawable="@drawable/progress_bar_cyan" />
        </LinearLayout>

        <!-- Display Card -->
        <LinearLayout
            style="@style/InfoCard"
            android:orientation="vertical">

            <TextView
                style="@style/SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/section_display"
                android:drawablePadding="8dp"
                android:drawableTint="@color/accent_purple" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="10dp"
                android:background="@color/divider" />

            <LinearLayout
                android:id="@+id/displayInfoContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>

        <!-- Battery Card -->
        <LinearLayout
            style="@style/InfoCard"
            android:orientation="vertical">

            <TextView
                style="@style/SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/section_battery"
                android:drawablePadding="8dp"
                android:drawableTint="@color/accent_yellow" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="10dp"
                android:background="@color/divider" />

            <LinearLayout
                android:id="@+id/batteryInfoContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <ProgressBar
                android:id="@+id/batteryProgressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="12dp"
                android:layout_marginTop="12dp"
                android:max="100"
                android:progressDrawable="@drawable/progress_bar_green" />
        </LinearLayout>

        <!-- Storage Card -->
        <LinearLayout
            style="@style/InfoCard"
            android:orientation="vertical">

            <TextView
                style="@style/SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/section_storage"
                android:drawablePadding="8dp"
                android:drawableTint="@color/accent_orange" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="10dp"
                android:background="@color/divider" />

            <LinearLayout
                android:id="@+id/storageInfoContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <ProgressBar
                android:id="@+id/storageProgressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="12dp"
                android:layout_marginTop="12dp"
                android:max="100"
                android:progressDrawable="@drawable/progress_bar_cyan" />
        </LinearLayout>

        <!-- Sensors Card -->
        <LinearLayout
            style="@style/InfoCard"
            android:orientation="vertical">

            <TextView
                style="@style/SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/section_sensors"
                android:drawablePadding="8dp"
                android:drawableTint="@color/accent_cyan" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="10dp"
                android:background="@color/divider" />

            <LinearLayout
                android:id="@+id/sensorsInfoContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
